rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/clients/{clientId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
            'id', 'name', 'phoneNumber', 'subscriptionType',
            'startDate', 'durationDays', 'expirationDate',
            'price', 'notes', 'isActive', 'createdAt'
           ])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200
        && request.resource.data.phoneNumber is string
        && request.resource.data.subscriptionType is string
        && request.resource.data.subscriptionType.size() <= 200
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 2000
        && request.resource.data.durationDays is int
        && request.resource.data.durationDays >= 0
        && request.resource.data.durationDays <= 3650
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.isActive is bool;
    }
  }
}
